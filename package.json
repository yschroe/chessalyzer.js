{
    "name": "chessalyzer.js",
    "version": "3.0.6",
    "description": "A JavaScript library for batch analyzing chess games.",
    "keywords": [
        "analysis",
        "batch",
        "chess",
        "heatmap",
        "pgn"
    ],
    "homepage": "https://github.com/yschroe/chessalyzer.js",
    "bugs": {
        "url": "https://github.com/yschroe/chessalyzer.js/issues"
    },
    "license": "MIT",
    "author": "Yannik Schröder",
    "repository": {
        "type": "git",
        "url": "https://github.com/yschroe/chessalyzer.js"
    },
    "files": [
        "lib/**/*"
    ],
    "type": "module",
    "main": "lib/chessalyzer.js",
    "types": "lib/chessalyzer.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        }
    },
    "scripts": {
        "build": "bun ./scripts/create-bundle.ts",
        "docs": "typedoc",
        "test": "bun test",
        "lint": "oxlint",
        "format": "oxfmt",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "chalk": "^5.6.2"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "bun-plugin-dts": "^0.4.0",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "oxlint-tsgolint": "^0.25.0",
        "typedoc": "^0.28.20",
        "typedoc-plugin-merge-modules": "^7.0.0",
        "typescript": "^7.0.2"
    },
    "overrides": {
        "@types/node": "^26.1.1"
    },
    "engines": {
        "node": ">=22"
    }
}
