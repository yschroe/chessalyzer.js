{
    "include": ["src/**/*", "scripts/**/*", "test/**/*", "manual-tests/**/*"],
    "compilerOptions": {
        "target": "ESNext",
        "module": "Preserve",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "outDir": "./lib",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true
        // "strictNullChecks": true
    }
}
